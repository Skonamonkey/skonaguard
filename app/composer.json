{
    "name": "skonamonkey/skonaguard",
    "description": "Self-hosted WireGuard VPN manager",
    "type": "project",
    "require": {
        "php": "^8.1",
        "slim/slim": "^4.0",
        "slim/psr7": "^1.0",
        "slim/twig-view": "^3.0",
        "php-di/php-di": "^7.0",
        "php-di/slim-bridge": "^3.0",
        "vlucas/phpdotenv": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "SkonaGuard\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
