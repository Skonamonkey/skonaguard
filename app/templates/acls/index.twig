{% extends 'partials/layout.twig' %}

{% block title %}Access Rules — SkonaGuard{% endblock %}
{% block page_title %}Access Rules{% endblock %}

{% block content %}

{% if session.flash_error is defined and session.flash_error %}
<div class="alert alert-danger" id="flash-msg">{{ session.flash_error }}</div>
{% endif %}
{% if session.flash_success is defined and session.flash_success %}
<div class="alert alert-success" id="flash-msg">{{ session.flash_success }}</div>
{% endif %}

<div class="card" style="margin-bottom:16px; background:var(--surface-raised); border-color:var(--border-subtle)">
    <div class="card-body" style="padding:14px 20px">
        <p style="font-size:var(--font-sm); color:var(--text-secondary); margin:0">
            <strong style="color:var(--color-info)">How rules work:</strong>
            Rules are evaluated in priority order (lowest number first). Each rule matches traffic by source zone/IP → destination zone/IP.
            <strong>Inbound Only</strong> allows replies to connections initiated from the source, but blocks new connections from the destination back.
            Rules without a matching zone apply to all zones.
        </p>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <div class="card-title">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Access Rules
        </div>
        <button class="btn btn-primary btn-sm" onclick="openModal('modal-add')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Add Rule
        </button>
    </div>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th style="width:40px">#</th>
                    <th>Rule Name</th>
                    <th>Source</th>
                    <th>Destination</th>
                    <th>Access</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            {% for rule in rules %}
                <tr>
                    <td><span class="badge badge-info" style="font-variant-numeric:tabular-nums">{{ rule.priority }}</span></td>
                    <td><strong>{{ rule.name }}</strong></td>
                    <td>
                        {% if rule.src_zone_name %}
                            <span class="badge badge-info">{{ rule.src_zone_name }}</span>
                        {% else %}
                            <span style="color:var(--text-muted)">Any Zone</span>
                        {% endif %}
                        {% if rule.src_ip_override %}
                            <br><code style="font-size:0.7rem; color:var(--text-secondary)">{{ rule.src_ip_override }}</code>
                        {% endif %}
                    </td>
                    <td>
                        {% if rule.dst_zone_name %}
                            <span class="badge badge-info">{{ rule.dst_zone_name }}</span>
                        {% else %}
                            <span style="color:var(--text-muted)">Any Zone</span>
                        {% endif %}
                        {% if rule.dst_ip_override %}
                            <br><code style="font-size:0.7rem; color:var(--text-secondary)">{{ rule.dst_ip_override }}</code>
                        {% endif %}
                    </td>
                    <td>
                        {% if rule.rule_type == 'full' %}
                            <span class="badge badge-active"><span class="dot dot-green"></span> Full Access</span>
                        {% elseif rule.rule_type == 'established' %}
                            <span class="badge badge-info">Inbound Only</span>
                        {% elseif rule.rule_type == 'icmp_only' %}
                            <span class="badge badge-offline">ICMP / Ping Only</span>
                        {% elseif rule.rule_type == 'deny' %}
                            <span class="badge badge-inactive"><span class="dot dot-grey"></span> Deny All</span>
                        {% else %}
                            <span class="badge">{{ rule.rule_type }}</span>
                        {% endif %}
                    </td>
                    <td style="text-align:right; white-space:nowrap">
                        <button class="btn-icon" title="Edit"
                            onclick='openEditModal({{ rule|json_encode }})'>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                        </button>
                        <button class="btn-icon danger" title="Delete"
                            onclick="confirmDelete({{ rule.id }}, '{{ rule.name|e('js') }}')">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                        </button>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" style="text-align:center; color:var(--text-muted); padding:40px 0;">
                        No rules yet. Without rules, all VPN traffic between zones is permitted.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<!-- Add Rule Modal -->
<div class="modal-backdrop" id="modal-add">
    <div class="modal" style="max-width:600px">
        <div class="modal-header">
            <span class="modal-title">Add Access Rule</span>
            <button class="modal-close" onclick="closeModal('modal-add')">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <form method="POST" action="/acls">
            <div class="modal-body">
                <div class="form-row" style="margin-bottom:16px">
                    <div class="form-group">
                        <label>Rule Name</label>
                        <input type="text" name="name" placeholder="e.g. Office → Home (read-only)" required>
                    </div>
                    <div class="form-group" style="max-width:90px">
                        <label>Priority</label>
                        <input type="number" name="priority" value="100" min="1" max="999">
                    </div>
                </div>

                <div style="background:var(--surface-input); border:1px solid var(--border-input); border-radius:var(--radius-sm); padding:16px; margin-bottom:16px">
                    <p style="font-size:0.7rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:var(--text-muted); margin:0 0 12px">Traffic Match</p>
                    <div class="form-row" style="margin-bottom:12px">
                        <div class="form-group">
                            <label>Source Zone</label>
                            <select name="src_zone_id">
                                <option value="">Any Zone</option>
                                {% for zone in zones %}
                                <option value="{{ zone.id }}">{{ zone.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Source IP Override <span style="color:var(--text-muted)">(optional)</span></label>
                            <input type="text" name="src_ip_override" placeholder="e.g. 172.16.2.5/32">
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Destination Zone</label>
                            <select name="dst_zone_id">
                                <option value="">Any Zone</option>
                                {% for zone in zones %}
                                <option value="{{ zone.id }}">{{ zone.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Destination IP Override <span style="color:var(--text-muted)">(optional)</span></label>
                            <input type="text" name="dst_ip_override" placeholder="e.g. 172.16.1.0/24">
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label>Access Rule</label>
                    <select name="rule_type">
                        <option value="full">Full Access — both sides can communicate freely</option>
                        <option value="established">Inbound Only — source can initiate; destination can only reply</option>
                        <option value="icmp_only">ICMP / Ping Only — ping between zones, all other traffic blocked</option>
                        <option value="deny">Deny All — block all traffic in both directions</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" onclick="closeModal('modal-add')">Cancel</button>
                <button type="submit" class="btn btn-primary">Create Rule</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Rule Modal -->
<div class="modal-backdrop" id="modal-edit">
    <div class="modal" style="max-width:600px">
        <div class="modal-header">
            <span class="modal-title">Edit Access Rule</span>
            <button class="modal-close" onclick="closeModal('modal-edit')">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <form method="POST" action="" id="form-edit">
            <div class="modal-body">
                <div class="form-row" style="margin-bottom:16px">
                    <div class="form-group">
                        <label>Rule Name</label>
                        <input type="text" id="edit-name" name="name" required>
                    </div>
                    <div class="form-group" style="max-width:90px">
                        <label>Priority</label>
                        <input type="number" id="edit-priority" name="priority" min="1" max="999">
                    </div>
                </div>

                <div style="background:var(--surface-input); border:1px solid var(--border-input); border-radius:var(--radius-sm); padding:16px; margin-bottom:16px">
                    <p style="font-size:0.7rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:var(--text-muted); margin:0 0 12px">Traffic Match</p>
                    <div class="form-row" style="margin-bottom:12px">
                        <div class="form-group">
                            <label>Source Zone</label>
                            <select id="edit-src-zone" name="src_zone_id">
                                <option value="">Any Zone</option>
                                {% for zone in zones %}
                                <option value="{{ zone.id }}">{{ zone.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Source IP Override</label>
                            <input type="text" id="edit-src-ip" name="src_ip_override">
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Destination Zone</label>
                            <select id="edit-dst-zone" name="dst_zone_id">
                                <option value="">Any Zone</option>
                                {% for zone in zones %}
                                <option value="{{ zone.id }}">{{ zone.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Destination IP Override</label>
                            <input type="text" id="edit-dst-ip" name="dst_ip_override">
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label>Access Rule</label>
                    <select id="edit-rule-type" name="rule_type">
                        <option value="full">Full Access — both sides can communicate freely</option>
                        <option value="established">Inbound Only — source can initiate; destination can only reply</option>
                        <option value="icmp_only">ICMP / Ping Only — ping between zones, all other traffic blocked</option>
                        <option value="deny">Deny All — block all traffic in both directions</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" onclick="closeModal('modal-edit')">Cancel</button>
                <button type="submit" class="btn btn-primary">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<!-- Delete Confirm Modal -->
<div class="modal-backdrop" id="modal-delete">
    <div class="modal" style="max-width:400px">
        <div class="modal-header">
            <span class="modal-title">Delete Rule</span>
            <button class="modal-close" onclick="closeModal('modal-delete')">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="modal-body">
            <p style="color:var(--text-secondary)">Delete rule <strong id="delete-rule-name"></strong>? This cannot be undone.</p>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-ghost" onclick="closeModal('modal-delete')">Cancel</button>
            <form method="POST" action="" id="form-delete" style="margin:0">
                <button type="submit" class="btn btn-danger">Delete</button>
            </form>
        </div>
    </div>
</div>

{% endblock %}

{% block scripts %}
<script>
function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

document.querySelectorAll('.modal-backdrop').forEach(b => {
    b.addEventListener('click', e => { if (e.target === b) b.classList.remove('open'); });
});

function openEditModal(rule) {
    document.getElementById('edit-name').value     = rule.name;
    document.getElementById('edit-priority').value = rule.priority;
    document.getElementById('edit-src-zone').value = rule.src_zone_id ?? '';
    document.getElementById('edit-dst-zone').value = rule.dst_zone_id ?? '';
    document.getElementById('edit-src-ip').value   = rule.src_ip_override ?? '';
    document.getElementById('edit-dst-ip').value   = rule.dst_ip_override ?? '';
    document.getElementById('edit-rule-type').value = rule.rule_type;
    document.getElementById('form-edit').action    = '/acls/' + rule.id;
    openModal('modal-edit');
}

function confirmDelete(id, name) {
    document.getElementById('delete-rule-name').textContent = name;
    document.getElementById('form-delete').action = '/acls/' + id + '/delete';
    openModal('modal-delete');
}

setTimeout(() => {
    const el = document.getElementById('flash-msg');
    if (el) el.style.opacity = '0';
}, 4000);
</script>
{% endblock %}
