<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Set Up Two-Factor Authentication &mdash; SkonaGuard</title>
    <link rel="icon" href="/assets/favicon.ico">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/assets/theme.css">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: var(--font-family);
            background: var(--surface-bg);
            color: var(--text-primary);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }

        .wrap { width: 100%; max-width: 480px; }

        .login-logo {
            text-align: center;
            margin-bottom: 2rem;
        }
        .login-logo img { height: 52px; margin-bottom: 0.75rem; }
        .login-logo h1 { font-size: var(--font-xl); font-weight: 700; letter-spacing: -0.02em; }
        .login-logo p { color: var(--text-secondary); font-size: var(--font-sm); margin-top: 0.25rem; }

        .card {
            background: var(--surface-card);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-lg);
            padding: 2rem;
        }

        .alert-error {
            background: var(--color-danger-muted);
            border: 1px solid var(--color-danger);
            color: var(--color-danger);
            border-radius: var(--radius-md);
            padding: 0.75rem 1rem;
            font-size: var(--font-sm);
            margin-bottom: 1.25rem;
        }

        h2 {
            font-size: 1.1rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        .steps {
            counter-reset: steps;
            list-style: none;
            margin: 1.25rem 0;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }
        .steps li {
            counter-increment: steps;
            display: flex;
            align-items: flex-start;
            gap: 0.75rem;
        }
        .steps li::before {
            content: counter(steps);
            flex-shrink: 0;
            width: 24px;
            height: 24px;
            border-radius: 50%;
            background: var(--color-primary);
            color: #fff;
            font-size: 0.75rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-top: 1px;
        }

        .qr-wrap {
            text-align: center;
            margin: 1.5rem 0;
            padding: 1rem;
            background: #fff;
            border-radius: var(--radius-md);
        }
        #qr-canvas { display: block; margin: 0 auto; }

        .secret-wrap {
            background: var(--surface-input);
            border: 1px solid var(--border-input);
            border-radius: var(--radius-sm);
            padding: 0.65rem 1rem;
            font-family: monospace;
            font-size: 1rem;
            letter-spacing: 0.1em;
            text-align: center;
            word-break: break-all;
            margin-bottom: 1.5rem;
        }

        label {
            display: block;
            font-size: var(--font-sm);
            font-weight: 600;
            color: var(--text-secondary);
            margin-bottom: 0.5rem;
        }

        input[type="text"] {
            width: 100%;
            background: var(--surface-input);
            border: 1px solid var(--border-input);
            border-radius: var(--radius-md);
            color: var(--text-primary);
            font-family: var(--font-family);
            font-size: 1.5rem;
            font-weight: 700;
            letter-spacing: 0.3em;
            text-align: center;
            padding: 0.65rem 0.9rem;
            outline: none;
            transition: border-color var(--transition), box-shadow var(--transition);
        }
        input:focus {
            border-color: var(--color-primary);
            box-shadow: 0 0 0 3px var(--color-primary-muted);
        }

        .btn-primary {
            width: 100%;
            padding: 0.75rem;
            background: var(--color-primary);
            color: #fff;
            border: none;
            border-radius: var(--radius-md);
            font-family: var(--font-family);
            font-size: var(--font-base);
            font-weight: 600;
            cursor: pointer;
            margin-top: 0.75rem;
            transition: background var(--transition);
        }
        .btn-primary:hover { background: var(--color-primary-hover); }

        .back-link {
            text-align: center;
            margin-top: 1.5rem;
            font-size: var(--font-sm);
        }
        .back-link a { color: var(--color-primary); text-decoration: none; }

        .login-footer {
            text-align: center;
            margin-top: 1.5rem;
            font-size: var(--font-sm);
            color: var(--text-muted);
        }
    </style>
</head>
<body>
<div class="wrap">
    <div class="login-logo">
        <img src="/assets/icon.png" alt="SkonaGuard">
        <h1>SkonaGuard</h1>
        <p>Set Up Two-Factor Authentication</p>
    </div>

    <div class="card">
        {% if error %}
            <div class="alert-error">{{ error }}</div>
        {% endif %}

        <h2>Protect your account with an authenticator app</h2>
        <p style="color:var(--text-muted); font-size:0.875rem; margin-top:0.35rem">Use any TOTP app — Google Authenticator, Aegis, Authy, 1Password, Bitwarden, etc.</p>

        <ol class="steps">
            <li>Install an authenticator app on your phone if you haven't already.</li>
            <li>
                Scan the QR code below — or enter the secret key manually if your app supports it.
                <div class="qr-wrap">
                    <canvas id="qr-canvas"></canvas>
                </div>
                <p style="font-size:0.75rem; color:var(--text-muted); margin-bottom:0.5rem">Or enter this secret manually:</p>
                <div class="secret-wrap">{{ secret }}</div>
            </li>
            <li>Enter the 6-digit code your app shows to confirm setup.</li>
        </ol>

        <form method="POST" action="/2fa/setup">
            <div style="margin-bottom:1rem">
                <label for="totp_code">Confirmation Code</label>
                <input type="text" id="totp_code" name="totp_code" maxlength="6" pattern="[0-9]{6}" inputmode="numeric" placeholder="000000" required autocomplete="one-time-code">
            </div>
            <button type="submit" class="btn-primary">Activate Two-Factor Authentication</button>
        </form>
    </div>

    {% if voluntary %}
    <div class="back-link"><a href="/settings">&larr; Cancel</a></div>
    {% else %}
    <div class="back-link"><a href="/login">&larr; Back to login</a></div>
    {% endif %}
    <div class="login-footer">SkonaGuard &mdash; Skonamonkey Solutions</div>
</div>

<script src="https://cdn.jsdelivr.net/npm/qrcode@1.5.3/build/qrcode.min.js"></script>
<script>
document.getElementById('totp_code').addEventListener('input', function() {
    this.value = this.value.replace(/\D/g, '').slice(0, 6);
});

QRCode.toCanvas(document.getElementById('qr-canvas'), '{{ otpauth_uri|raw }}', {
    width: 220,
    margin: 2,
    color: { dark: '#000000', light: '#ffffff' }
}, function(err) {
    if (err) {
        document.querySelector('.qr-wrap').innerHTML = '<p style="color:var(--text-muted); font-size:0.8rem">QR code unavailable. Use the secret key below.</p>';
    }
});
</script>
</body>
</html>
