<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Set Up Two-Factor Authentication &mdash; SkonaGuard</title>
    <link rel="icon" href="/assets/favicon.ico">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/assets/theme.css">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: var(--font-family);
            background: var(--surface-bg);
            color: var(--text-primary);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }

        .wrap { width: 100%; max-width: 460px; }

        .login-logo { text-align: center; margin-bottom: 2rem; }
        .login-logo img { height: 52px; margin-bottom: 0.75rem; }
        .login-logo h1 { font-size: var(--font-xl); font-weight: 700; letter-spacing: -0.02em; }
        .login-logo p { color: var(--text-secondary); font-size: var(--font-sm); margin-top: 0.25rem; }

        .card {
            background: var(--surface-card);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-lg);
            padding: 2rem;
        }

        .alert-error {
            background: var(--color-danger-muted);
            border: 1px solid var(--color-danger);
            color: var(--color-danger);
            border-radius: var(--radius-md);
            padding: 0.75rem 1rem;
            font-size: var(--font-sm);
            margin-bottom: 1.25rem;
        }

        .step {
            display: flex;
            align-items: flex-start;
            gap: 0.75rem;
            margin-bottom: 1.25rem;
        }
        .step-num {
            flex-shrink: 0;
            width: 24px;
            height: 24px;
            border-radius: 50%;
            background: var(--color-primary);
            color: #fff;
            font-size: 0.75rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-top: 2px;
        }
        .step-body {
            flex: 1;
            min-width: 0;
            font-size: 0.875rem;
            color: var(--text-secondary);
        }

        .qr-wrap {
            text-align: center;
            margin: 1rem 0 0.75rem;
            padding: 1rem;
            background: #fff;
            border-radius: var(--radius-md);
            display: inline-block;
            width: 100%;
        }
        #qr-canvas { display: flex; justify-content: center; align-items: center; }
        #qr-canvas canvas, #qr-canvas img { display: block; margin: 0 auto; }

        .secret-box {
            background: var(--surface-input);
            border: 1px solid var(--border-input);
            border-radius: var(--radius-sm);
            padding: 0.6rem 0.9rem;
            font-family: monospace;
            font-size: 0.9rem;
            letter-spacing: 0.12em;
            text-align: center;
            word-break: break-all;
            width: 100%;
            margin-top: 0.5rem;
        }

        .divider {
            border: none;
            border-top: 1px solid var(--border-color);
            margin: 1.5rem 0;
        }

        label {
            display: block;
            font-size: var(--font-sm);
            font-weight: 600;
            color: var(--text-secondary);
            margin-bottom: 0.5rem;
        }

        input[type="text"] {
            width: 100%;
            background: var(--surface-input);
            border: 1px solid var(--border-input);
            border-radius: var(--radius-md);
            color: var(--text-primary);
            font-family: var(--font-family);
            font-size: 1.5rem;
            font-weight: 700;
            letter-spacing: 0.3em;
            text-align: center;
            padding: 0.65rem 0.9rem;
            outline: none;
            transition: border-color var(--transition), box-shadow var(--transition);
        }
        input:focus {
            border-color: var(--color-primary);
            box-shadow: 0 0 0 3px var(--color-primary-muted);
        }

        .btn-primary {
            width: 100%;
            padding: 0.75rem;
            background: var(--color-primary);
            color: #fff;
            border: none;
            border-radius: var(--radius-md);
            font-family: var(--font-family);
            font-size: var(--font-base);
            font-weight: 600;
            cursor: pointer;
            margin-top: 0.75rem;
            transition: background var(--transition);
        }
        .btn-primary:hover { background: var(--color-primary-hover); }

        .back-link { text-align: center; margin-top: 1.5rem; font-size: var(--font-sm); }
        .back-link a { color: var(--color-primary); text-decoration: none; }

        .login-footer { text-align: center; margin-top: 1.5rem; font-size: var(--font-sm); color: var(--text-muted); }
    </style>
</head>
<body>
<div class="wrap">
    <div class="login-logo">
        <img src="/assets/icon.png" alt="SkonaGuard">
        <h1>SkonaGuard</h1>
        <p>Set Up Two-Factor Authentication</p>
    </div>

    <div class="card">
        {% if error %}
            <div class="alert-error">{{ error }}</div>
        {% endif %}

        <div style="margin-bottom:1.25rem">
            <strong style="font-size:1.05rem">Protect your account with an authenticator app</strong>
            <p style="color:var(--text-muted); font-size:0.8rem; margin-top:0.3rem">Works with Google Authenticator, Aegis, Authy, 1Password, Bitwarden, and any TOTP app.</p>
        </div>

        <div class="step">
            <div class="step-num">1</div>
            <div class="step-body">Install an authenticator app on your phone if you haven't already.</div>
        </div>

        <div class="step">
            <div class="step-num">2</div>
            <div class="step-body">
                <span>Open your app and scan the QR code below.</span>
                <div class="qr-wrap">
                    <canvas id="qr-canvas"></canvas>
                </div>
                <p style="font-size:0.75rem; color:var(--text-muted); margin-top:0.5rem">Can't scan? Enter this secret key manually in your app:</p>
                <div class="secret-box">{{ secret }}</div>
            </div>
        </div>

        <div class="step">
            <div class="step-num">3</div>
            <div class="step-body">Enter the 6-digit code from your app below to confirm setup.</div>
        </div>

        <hr class="divider">

        <form method="POST" action="/2fa/setup">
            <div style="margin-bottom:1rem">
                <label for="totp_code">Confirmation Code</label>
                <input type="text" id="totp_code" name="totp_code" maxlength="6" pattern="[0-9]{6}" inputmode="numeric" placeholder="000000" required autocomplete="one-time-code">
            </div>
            <button type="submit" class="btn-primary">Activate Two-Factor Authentication</button>
        </form>
    </div>

    {% if voluntary %}
    <div class="back-link"><a href="/settings">&larr; Cancel</a></div>
    {% else %}
    <div class="back-link"><a href="/login">&larr; Back to login</a></div>
    {% endif %}
    <div class="login-footer">SkonaGuard &mdash; Skonamonkey Solutions</div>
</div>

<script src="/assets/qrcode.min.js"></script>
<script>
document.getElementById('totp_code').addEventListener('input', function() {
    this.value = this.value.replace(/\D/g, '').slice(0, 6);
});

var otpauthUri = {{ otpauth_uri|json_encode }};

try {
    new QRCode(document.getElementById('qr-canvas'), {
        text: otpauthUri,
        width: 200,
        height: 200,
        colorDark: '#000000',
        colorLight: '#ffffff',
    });
} catch (e) {
    document.querySelector('.qr-wrap').innerHTML = '<p style="padding:1rem; color:#555; font-size:0.8rem">QR unavailable — use the secret key above.</p>';
}
</script>
</body>
</html>
