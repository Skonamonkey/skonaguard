{% extends 'partials/layout.twig' %}

{% block title %}Settings — SkonaGuard{% endblock %}
{% block page_title %}Settings{% endblock %}

{% block content %}

{% if session.flash_error is defined and session.flash_error %}
<div class="alert alert-danger" id="flash-msg">{{ session.flash_error }}</div>
{% endif %}
{% if session.flash_success is defined and session.flash_success %}
<div class="alert alert-success" id="flash-msg">{{ session.flash_success }}</div>
{% endif %}

<div style="display:grid; gap:24px; grid-template-columns: 1fr 1fr">

<!-- Server Settings -->
<div class="card" style="grid-column:1/-1">
    <div class="card-header">
        <div class="card-title">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            WireGuard Server
        </div>
    </div>
    <div class="card-body">
        <form method="POST" action="/settings">
            <input type="hidden" name="action" value="server">
            <div style="background:var(--surface-input); border:1px solid var(--border-input); border-radius:var(--radius-sm); padding:16px; margin-bottom:16px">
                <p style="font-size:0.7rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:var(--text-muted); margin:0 0 12px">Endpoints — used in peer .conf files</p>
                <div class="form-row">
                    <div class="form-group">
                        <label>WAN / Public Endpoint <span style="color:var(--color-danger)">*</span></label>
                        <input type="text" name="server_public_ip" value="{{ settings.server_public_ip ?? '' }}" placeholder="e.g. 213.171.194.152 or vpn.example.com">
                        <small style="color:var(--text-muted)">Public IP or hostname — for peers connecting over the internet.</small>
                    </div>
                    <div class="form-group">
                        <label>LAN / Local Endpoint <span style="color:var(--text-muted)">(optional)</span></label>
                        <input type="text" name="server_lan_ip" value="{{ settings.server_lan_ip ?? '' }}" placeholder="e.g. 192.168.1.50">
                        <small style="color:var(--text-muted)">LAN IP — if set, peers on the same network can download a local config.</small>
                    </div>
                </div>
            </div>
            <div class="form-row" style="margin-bottom:16px">
                <div class="form-group">
                    <label>WireGuard Port</label>
                    <input type="text" name="wg_port" value="{{ settings.wg_port ?? '51820' }}" placeholder="51820">
                </div>
                <div class="form-group">
                    <label>VPN Subnet</label>
                    <input type="text" name="wg_subnet" value="{{ settings.wg_subnet ?? '' }}" placeholder="172.16.0.0/16">
                </div>
            </div>
            <div class="info-row">
                <div class="info-label">Server Public Key</div>
                <div class="info-value">
                    <div class="copy-wrap">
                        <div class="code-block" id="pub-key">{{ settings.server_public_key ?? 'Not generated' }}</div>
                        <button type="button" class="copy-btn" onclick="copyText('pub-key')" title="Copy">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                        </button>
                    </div>
                </div>
            </div>
            <div style="margin-top:16px">
                <button type="submit" class="btn btn-primary">Save &amp; Apply</button>
            </div>
        </form>
    </div>
</div>

<!-- Change Password -->
<div class="card">
    <div class="card-header">
        <div class="card-title">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            Change Password
        </div>
    </div>
    <div class="card-body">
        <form method="POST" action="/settings">
            <input type="hidden" name="action" value="password">
            <div class="form-group" style="margin-bottom:14px">
                <label>Current Password</label>
                <input type="password" name="current_password" required autocomplete="current-password">
            </div>
            <div class="form-group" style="margin-bottom:14px">
                <label>New Password</label>
                <input type="password" name="new_password" required minlength="8" autocomplete="new-password">
            </div>
            <div class="form-group" style="margin-bottom:18px">
                <label>Confirm New Password</label>
                <input type="password" name="confirm_password" required autocomplete="new-password">
            </div>
            <button type="submit" class="btn btn-primary">Update Password</button>
        </form>
    </div>
</div>

<!-- ACL Enforcement -->
<div class="card">
    <div class="card-header">
        <div class="card-title">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            ACL Enforcement
        </div>
    </div>
    <div class="card-body">
        <p style="color:var(--text-muted); font-size:0.875rem; margin-bottom:16px">
            When enabled, iptables rules are applied to enforce zone access control lists. An isolated <code>SKONAGUARD</code> chain is used — existing firewall rules are never modified. Safe to toggle at any time.
        </p>
        <form method="POST" action="/settings">
            <input type="hidden" name="action" value="acl">
            <label style="display:flex; align-items:center; gap:12px; cursor:pointer; margin-bottom:18px">
                <div style="position:relative; width:44px; height:24px; flex-shrink:0">
                    <input type="checkbox" name="acl_enforcement" id="acl-toggle" value="1" style="opacity:0; width:0; height:0; position:absolute"
                        {{ (settings.acl_enforcement ?? '0') == '1' ? 'checked' : '' }}>
                    <span id="acl-track" style="position:absolute; inset:0; border-radius:12px; background:{{ (settings.acl_enforcement ?? '0') == '1' ? 'var(--color-primary)' : 'var(--border-color)' }}; transition:background 0.2s">
                        <span id="acl-thumb" style="position:absolute; top:3px; left:{{ (settings.acl_enforcement ?? '0') == '1' ? '23px' : '3px' }}; width:18px; height:18px; border-radius:50%; background:#fff; transition:left 0.2s"></span>
                    </span>
                </div>
                <span style="font-weight:600">Enable ACL enforcement</span>
            </label>

            <div style="margin-bottom:20px">
                <label style="display:block; font-size:0.8rem; font-weight:600; color:var(--text-secondary); margin-bottom:8px">Default Policy <span style="font-weight:400; color:var(--text-muted)">(when no rule matches)</span></label>
                <div style="display:flex; gap:10px">
                    <label style="flex:1; display:flex; align-items:flex-start; gap:10px; padding:12px 14px; border-radius:var(--radius-sm); border:2px solid {{ (settings.acl_default_policy ?? 'permissive') == 'permissive' ? 'var(--color-primary)' : 'var(--border-input)' }}; cursor:pointer; background:var(--surface-input)" id="policy-permissive-label">
                        <input type="radio" name="acl_default_policy" value="permissive" id="policy-permissive" style="margin-top:2px; flex-shrink:0" {{ (settings.acl_default_policy ?? 'permissive') == 'permissive' ? 'checked' : '' }}>
                        <div>
                            <div style="font-weight:600; font-size:0.875rem">Permissive</div>
                            <div style="font-size:0.75rem; color:var(--text-muted); margin-top:2px">Allow traffic that doesn't match any rule. Best for gradual rollout.</div>
                        </div>
                    </label>
                    <label style="flex:1; display:flex; align-items:flex-start; gap:10px; padding:12px 14px; border-radius:var(--radius-sm); border:2px solid {{ (settings.acl_default_policy ?? 'permissive') == 'restrictive' ? 'var(--color-danger)' : 'var(--border-input)' }}; cursor:pointer; background:var(--surface-input)" id="policy-restrictive-label">
                        <input type="radio" name="acl_default_policy" value="restrictive" id="policy-restrictive" style="margin-top:2px; flex-shrink:0" {{ (settings.acl_default_policy ?? 'permissive') == 'restrictive' ? 'checked' : '' }}>
                        <div>
                            <div style="font-weight:600; font-size:0.875rem; color:var(--color-danger)">Restrictive</div>
                            <div style="font-size:0.75rem; color:var(--text-muted); margin-top:2px">Block all traffic not matched by a rule. Requires explicit allow rules for everything.</div>
                        </div>
                    </label>
                </div>
            </div>

            <button type="submit" class="btn btn-primary">Apply</button>
        </form>
    </div>
</div>

<!-- DNS Server -->
<div class="card" style="grid-column:1/-1">
    <div class="card-header">
        <div class="card-title">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
            DNS Server
        </div>
    </div>
    <div class="card-body">
        <p style="color:var(--text-muted); font-size:0.875rem; margin-bottom:16px">
            Optional built-in DNS server (dnsproxy). When enabled, peers can resolve each other by name — e.g. <code>proxmox.home.skona</code>. Forwards all other queries to your chosen upstream. The DNS IP is always reachable by all peers regardless of ACL rules.
        </p>
        <form method="POST" action="/settings">
            <input type="hidden" name="action" value="dns">
            <label style="display:flex; align-items:center; gap:12px; cursor:pointer; margin-bottom:20px">
                <div style="position:relative; width:44px; height:24px; flex-shrink:0">
                    <input type="checkbox" name="dns_enabled" id="dns-toggle" value="1" style="opacity:0; width:0; height:0; position:absolute"
                        {{ (settings.dns_enabled ?? '0') == '1' ? 'checked' : '' }}>
                    <span id="dns-track" style="position:absolute; inset:0; border-radius:12px; background:{{ (settings.dns_enabled ?? '0') == '1' ? 'var(--color-primary)' : 'var(--border-color)' }}; transition:background 0.2s">
                        <span id="dns-thumb" style="position:absolute; top:3px; left:{{ (settings.dns_enabled ?? '0') == '1' ? '23px' : '3px' }}; width:18px; height:18px; border-radius:50%; background:#fff; transition:left 0.2s"></span>
                    </span>
                </div>
                <span style="font-weight:600">Enable DNS server</span>
            </label>
            <div class="form-row" style="margin-bottom:16px">
                <div class="form-group">
                    <label>Domain Suffix</label>
                    <input type="text" name="dns_domain" value="{{ settings.dns_domain ?? 'skona' }}" placeholder="skona">
                    <small style="color:var(--text-muted)">Peers resolve as <code>{hostname}.{zone}.{suffix}</code> — e.g. <code>proxmox.home.skona</code></small>
                </div>
                <div class="form-group">
                    <label>Upstream Resolver</label>
                    <input type="text" name="dns_upstream" value="{{ settings.dns_upstream ?? '9.9.9.9' }}" placeholder="9.9.9.9">
                    <small style="color:var(--text-muted)">Comma-separated. Plain: <code>9.9.9.9</code> &nbsp;|&nbsp; DoT: <code>tls://9.9.9.9</code> &nbsp;|&nbsp; DoH: <code>https://dns.quad9.net/dns-query</code><br>Example: <code>tls://9.9.9.9, tls://1.1.1.1</code></small>
                </div>
            </div>
            <button type="submit" class="btn btn-primary">Apply</button>
        </form>
    </div>
</div>

<!-- About -->
<div class="card">
    <div class="card-header">
        <div class="card-title">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            About
        </div>
    </div>
    <div class="card-body">
        <div class="info-row">
            <div class="info-label">Application</div>
            <div class="info-value">SkonaGuard</div>
        </div>
        <div class="info-row">
            <div class="info-label">Version</div>
            <div class="info-value">{{ app_version }}</div>
        </div>
        <div class="info-row">
            <div class="info-label">VPN Backend</div>
            <div class="info-value">wireguard-go (userspace)</div>
        </div>
        <div class="info-row">
            <div class="info-label">Database</div>
            <div class="info-value">SQLite (WAL mode)</div>
        </div>
        <div class="info-row">
            <div class="info-label">Logged in as</div>
            <div class="info-value">{{ session.username }}</div>
        </div>
    </div>
</div>

</div>

{% endblock %}

{% block scripts %}
<script>
function copyText(id) {
    navigator.clipboard.writeText(document.getElementById(id).textContent.trim()).catch(()=>{});
}
setTimeout(() => {
    const el = document.getElementById('flash-msg');
    if (el) el.style.opacity = '0';
}, 4000);

const aclToggle = document.getElementById('acl-toggle');
const aclTrack  = document.getElementById('acl-track');
const aclThumb  = document.getElementById('acl-thumb');
if (aclToggle) {
    aclToggle.addEventListener('change', () => {
        const on = aclToggle.checked;
        aclTrack.style.background = on ? 'var(--color-primary)' : 'var(--border-color)';
        aclThumb.style.left = on ? '23px' : '3px';
    });
}

const policyRadios = document.querySelectorAll('input[name="acl_default_policy"]');
const permLabel = document.getElementById('policy-permissive-label');
const restLabel = document.getElementById('policy-restrictive-label');
function updatePolicyHighlight() {
    const val = document.querySelector('input[name="acl_default_policy"]:checked')?.value ?? 'permissive';
    if (permLabel) permLabel.style.borderColor = val === 'permissive' ? 'var(--color-primary)' : 'var(--border-input)';
    if (restLabel) restLabel.style.borderColor = val === 'restrictive' ? 'var(--color-danger)' : 'var(--border-input)';
}
policyRadios.forEach(r => r.addEventListener('change', updatePolicyHighlight));

const dnsToggle = document.getElementById('dns-toggle');
const dnsTrack  = document.getElementById('dns-track');
const dnsThumb  = document.getElementById('dns-thumb');
if (dnsToggle) {
    dnsToggle.addEventListener('change', () => {
        const on = dnsToggle.checked;
        dnsTrack.style.background = on ? 'var(--color-primary)' : 'var(--border-color)';
        dnsThumb.style.left = on ? '23px' : '3px';
    });
}
</script>
{% endblock %}
