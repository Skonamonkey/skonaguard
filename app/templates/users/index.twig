{% extends 'partials/layout.twig' %}
{% block title %}Users — SkonaGuard{% endblock %}
{% block page_title %}Users{% endblock %}

{% block content %}
{% if session.flash_success is defined %}
<div class="alert alert-success">{{ session.flash_success }}</div>
{% endif %}
{% if session.flash_error is defined %}
<div class="alert alert-error">{{ session.flash_error }}</div>
{% endif %}

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem">
    <div>
        <h2 style="margin:0; font-size:1.25rem; font-weight:700">Admin Users</h2>
        <p style="margin:0.25rem 0 0; color:var(--text-muted); font-size:0.875rem">Manage who has access and what they can do.</p>
    </div>
    <button class="btn btn-primary" onclick="openModal('modal-add')">+ Add User</button>
</div>

<div class="card">
    <div class="card-body" style="padding:0">
        <table class="table">
            <thead>
                <tr>
                    <th>Username</th>
                    <th>Display Name</th>
                    <th>Role</th>
                    <th>Zone Access</th>
                    <th>Created</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                <tr>
                    <td style="font-weight:600">
                        {{ user.username }}
                        {% if user.id == session.user_id %}<span style="font-size:0.7rem; color:var(--color-primary); margin-left:6px">(you)</span>{% endif %}
                    </td>
                    <td style="color:var(--text-muted)">{{ user.display_name ?? '—' }}</td>
                    <td>
                        {% if user.role == 'superadmin' %}
                            <span class="badge badge-blue">Super Admin</span>
                        {% elseif user.role == 'admin' %}
                            <span class="badge badge-green">Admin</span>
                        {% else %}
                            <span class="badge">Zone Admin</span>
                        {% endif %}
                    </td>
                    <td style="color:var(--text-muted); font-size:0.8rem">
                        {% if user.role == 'superadmin' or user.role == 'admin' %}
                            All zones
                        {% elseif user.zone_ids %}
                            {% set zids = user.zone_ids|split(',') %}
                            {% set znames = [] %}
                            {% for z in zones %}
                                {% if z.id|string in zids %}
                                    {% set znames = znames|merge([z.name]) %}
                                {% endif %}
                            {% endfor %}
                            {{ znames|join(', ') ?: '—' }}
                        {% else %}
                            <span style="color:var(--color-warning)">No zones assigned</span>
                        {% endif %}
                    </td>
                    <td style="color:var(--text-muted); font-size:0.8rem">{{ user.created_at|slice(0,10) }}</td>
                    <td style="text-align:right">
                        <button class="btn btn-ghost btn-sm" onclick='openEditModal({{ user|json_encode }}, {{ zones|json_encode }})'>Edit</button>
                        {% if user.id != session.user_id %}
                        <form method="POST" action="/users/{{ user.id }}/delete" style="display:inline" onsubmit="return confirm('Delete user {{ user.username }}?')">
                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                        </form>
                        {% endif %}
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="6" style="text-align:center; color:var(--text-muted); padding:2rem">No users yet.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<!-- Role guide -->
<div class="card" style="margin-top:1.5rem">
    <div class="card-header"><div class="card-title">Role Permissions</div></div>
    <div class="card-body">
        <table class="table" style="font-size:0.85rem">
            <thead><tr><th>Feature</th><th>Super Admin</th><th>Admin</th><th>Zone Admin</th></tr></thead>
            <tbody>
                <tr><td>Dashboard</td><td>✓</td><td>✓</td><td>✓</td></tr>
                <tr><td>Peers (all zones)</td><td>✓</td><td>✓</td><td>—</td></tr>
                <tr><td>Peers (assigned zones)</td><td>✓</td><td>✓</td><td>✓</td></tr>
                <tr><td>Profiles</td><td>✓</td><td>✓</td><td>—</td></tr>
                <tr><td>Zones</td><td>✓</td><td>—</td><td>—</td></tr>
                <tr><td>Access Rules (ACL)</td><td>✓</td><td>—</td><td>—</td></tr>
                <tr><td>Settings</td><td>✓</td><td>—</td><td>—</td></tr>
                <tr><td>Users</td><td>✓</td><td>—</td><td>—</td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Add User Modal -->
<div class="modal-backdrop" id="modal-add">
    <div class="modal" style="max-width:500px">
        <div class="modal-header">
            <span class="modal-title">Add User</span>
            <button class="modal-close" onclick="closeModal('modal-add')">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <form method="POST" action="/users">
            <div class="modal-body">
                <div class="form-row" style="margin-bottom:16px">
                    <div class="form-group">
                        <label>Username <span style="color:var(--color-danger)">*</span></label>
                        <input type="text" name="username" required autocomplete="off">
                    </div>
                    <div class="form-group">
                        <label>Display Name</label>
                        <input type="text" name="display_name" placeholder="Optional">
                    </div>
                </div>
                <div class="form-group" style="margin-bottom:16px">
                    <label>Password <span style="color:var(--color-danger)">*</span></label>
                    <input type="password" name="password" required minlength="8" autocomplete="new-password">
                    <small style="color:var(--text-muted)">Minimum 8 characters.</small>
                </div>
                <div class="form-group" style="margin-bottom:16px">
                    <label>Role</label>
                    <select name="role" id="add-role" onchange="toggleZonePicker('add-zones', this.value)">
                        <option value="admin">Admin</option>
                        <option value="superadmin">Super Admin</option>
                        <option value="zone_admin">Zone Admin</option>
                    </select>
                </div>
                <div id="add-zones" style="display:none">
                    <div class="form-group">
                        <label>Allowed Zones</label>
                        <div style="display:flex; flex-direction:column; gap:6px; padding:10px; background:var(--surface-input); border:1px solid var(--border-input); border-radius:var(--radius-sm)">
                            {% for zone in zones %}
                            <label style="display:flex; align-items:center; gap:8px; cursor:pointer; font-weight:normal">
                                <input type="checkbox" name="zone_ids[]" value="{{ zone.id }}">
                                {{ zone.name }} <span style="color:var(--text-muted); font-size:0.8rem">({{ zone.subnet }})</span>
                            </label>
                            {% else %}
                            <span style="color:var(--text-muted)">No zones available.</span>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" onclick="closeModal('modal-add')">Cancel</button>
                <button type="submit" class="btn btn-primary">Create User</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit User Modal -->
<div class="modal-backdrop" id="modal-edit">
    <div class="modal" style="max-width:500px">
        <div class="modal-header">
            <span class="modal-title">Edit User</span>
            <button class="modal-close" onclick="closeModal('modal-edit')">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <form method="POST" action="" id="form-edit">
            <div class="modal-body">
                <div class="form-row" style="margin-bottom:16px">
                    <div class="form-group">
                        <label>Username <span style="color:var(--color-danger)">*</span></label>
                        <input type="text" id="edit-username" name="username" required autocomplete="off">
                    </div>
                    <div class="form-group">
                        <label>Display Name</label>
                        <input type="text" id="edit-display-name" name="display_name" placeholder="Optional">
                    </div>
                </div>
                <div class="form-group" style="margin-bottom:16px">
                    <label>New Password</label>
                    <input type="password" name="password" minlength="8" autocomplete="new-password" placeholder="Leave blank to keep current">
                </div>
                <div class="form-group" style="margin-bottom:16px">
                    <label>Role</label>
                    <select name="role" id="edit-role" onchange="toggleZonePicker('edit-zones', this.value)">
                        <option value="admin">Admin</option>
                        <option value="superadmin">Super Admin</option>
                        <option value="zone_admin">Zone Admin</option>
                    </select>
                </div>
                <div id="edit-zones" style="display:none">
                    <div class="form-group">
                        <label>Allowed Zones</label>
                        <div id="edit-zone-list" style="display:flex; flex-direction:column; gap:6px; padding:10px; background:var(--surface-input); border:1px solid var(--border-input); border-radius:var(--radius-sm)"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" onclick="closeModal('modal-edit')">Cancel</button>
                <button type="submit" class="btn btn-primary">Save Changes</button>
            </div>
        </form>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
function toggleZonePicker(id, role) {
    document.getElementById(id).style.display = role === 'zone_admin' ? 'block' : 'none';
}

function openEditModal(user, zones) {
    document.getElementById('edit-username').value     = user.username;
    document.getElementById('edit-display-name').value = user.display_name ?? '';
    document.getElementById('edit-role').value         = user.role;
    document.getElementById('form-edit').action        = '/users/' + user.id;

    const assignedIds = user.zone_ids ? user.zone_ids.toString().split(',') : [];
    const list = document.getElementById('edit-zone-list');
    list.innerHTML = zones.map(z => `
        <label style="display:flex; align-items:center; gap:8px; cursor:pointer; font-weight:normal">
            <input type="checkbox" name="zone_ids[]" value="${z.id}" ${assignedIds.includes(String(z.id)) ? 'checked' : ''}>
            ${z.name} <span style="color:var(--text-muted); font-size:0.8rem">(${z.subnet})</span>
        </label>
    `).join('') || '<span style="color:var(--text-muted)">No zones available.</span>';

    toggleZonePicker('edit-zones', user.role);
    openModal('modal-edit');
}
</script>
{% endblock %}
