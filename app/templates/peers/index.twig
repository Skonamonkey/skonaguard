{% extends 'partials/layout.twig' %}

{% block title %}Peers — SkonaGuard{% endblock %}
{% block page_title %}Peers{% endblock %}

{% block head %}
<style>
.peer-row td { vertical-align: middle; }
.peer-actions { display:flex; gap:4px; justify-content:flex-end; flex-wrap:nowrap; }
.qr-canvas { display:block; margin:0 auto; }
.token-result { display:none; margin-top:12px; }
.token-result.show { display:block; }
</style>
{% endblock %}

{% block content %}

{% if session.flash_error is defined and session.flash_error %}
<div class="alert alert-danger" id="flash-msg">{{ session.flash_error }}</div>
{% endif %}
{% if session.flash_success is defined and session.flash_success %}
<div class="alert alert-success" id="flash-msg">{{ session.flash_success }}</div>
{% endif %}

<div class="card">
    <div class="card-header">
        <div class="card-title">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
            VPN Peers
        </div>
        <button class="btn btn-primary btn-sm" onclick="openModal('modal-add')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Add Peer
        </button>
    </div>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Zone</th>
                    <th>VPN IP</th>
                    <th>Profile</th>
                    <th>Gateway</th>
                    <th>Transfer (↓ rx / ↑ tx)</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            {% for peer in peers %}
                <tr class="peer-row" data-pubkey="{{ peer.public_key }}">
                    <td>
                        <strong>{{ peer.name }}</strong>
                        {% if peer.hostname and peer.zone_dns_name %}
                        <br><small style="color:var(--text-muted); font-family:monospace; font-size:0.7rem">
                            {{- peer.hostname ~ '.' ~ peer.zone_dns_name ~ '.' ~ dns_domain -}}
                            {%- if peer.dns_alias %} &middot; {{ peer.dns_alias ~ '.' ~ dns_domain }}{% endif %}
                        </small>
                        {% elseif peer.dns_alias %}
                        <br><small style="color:var(--text-muted); font-family:monospace; font-size:0.7rem">{{ peer.dns_alias ~ '.' ~ dns_domain }}</small>
                        {% endif %}
                        {% if peer.notes %}<br><small style="color:var(--text-muted)">{{ peer.notes }}</small>{% endif %}
                    </td>
                    <td><span class="badge badge-info">{{ peer.zone_name }}</span></td>
                    <td><code style="font-size:0.8rem">{{ peer.vpn_ip }}</code></td>
                    <td>{{ peer.profile_name ?? '—' }}</td>
                    <td>
                        {% if peer.is_gateway %}
                            <span class="badge badge-active">
                                <span class="dot dot-green"></span> Gateway
                            </span>
                            {% if peer.gateway_subnet %}
                            <br><small style="color:var(--text-muted)">{{ peer.gateway_subnet }}</small>
                            {% endif %}
                        {% else %}
                            <span style="color:var(--text-muted)">—</span>
                        {% endif %}
                    </td>
                    <td class="peer-transfer" style="font-family:monospace; font-size:0.75rem; color:var(--text-muted)">—</td>
                    <td>
                        {% if peer.enabled %}
                            <span class="badge badge-active"><span class="dot dot-green"></span> Enabled</span>
                        {% else %}
                            <span class="badge badge-inactive"><span class="dot dot-grey"></span> Disabled</span>
                        {% endif %}
                    </td>
                    <td>
                        <div class="peer-actions">
                            <button class="btn-icon" title="Edit" onclick='openEditModal({{ peer|json_encode }})'>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                            </button>
                            {% if has_lan_endpoint %}
                            <div class="btn-split" title="Download .conf">
                                <a href="/peers/{{ peer.id }}/download" class="btn-icon btn-split-main" title="Download WAN config">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                                </a>
                                <button class="btn-icon btn-split-toggle" onclick="toggleDownloadMenu({{ peer.id }})" title="More download options">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                                </button>
                                <div class="btn-split-menu" id="dl-menu-{{ peer.id }}" style="display:none">
                                    <a href="/peers/{{ peer.id }}/download" class="split-menu-item">⬇ WAN Config (internet)</a>
                                    <a href="/peers/{{ peer.id }}/download?mode=lan" class="split-menu-item">⬇ LAN Config (local network)</a>
                                    <button class="split-menu-item" onclick="showQr({{ peer.id }}, '{{ peer.name|e('js') }}', 'wan')">⬛ QR — WAN</button>
                                    <button class="split-menu-item" onclick="showQr({{ peer.id }}, '{{ peer.name|e('js') }}', 'lan')">⬛ QR — LAN</button>
                                </div>
                            </div>
                            {% else %}
                            <a href="/peers/{{ peer.id }}/download" class="btn-icon" title="Download .conf">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                            </a>
                            <button class="btn-icon" title="QR Code" onclick="showQr({{ peer.id }}, '{{ peer.name|e('js') }}', 'wan')">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                            </button>
                            {% endif %}
                            <button class="btn-icon" title="Create Share Link" onclick="openTokenModal({{ peer.id }}, '{{ peer.name|e('js') }}')">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                            </button>
                            <button class="btn-icon danger" title="Delete" onclick="confirmDelete({{ peer.id }}, '{{ peer.name|e('js') }}')">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                            </button>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7" style="text-align:center; color:var(--text-muted); padding:40px 0;">
                        No peers yet. Add one to get started.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<!-- Add Peer Modal -->
<div class="modal-backdrop" id="modal-add">
    <div class="modal" style="max-width:600px">
        <div class="modal-header">
            <span class="modal-title">Add Peer</span>
            <button class="modal-close" onclick="closeModal('modal-add')">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <form method="POST" action="/peers">
            <div class="modal-body">
                <div class="form-row" style="margin-bottom:16px">
                    <div class="form-group">
                        <label>Peer Name</label>
                        <input type="text" name="name" id="add-peer-name" placeholder="e.g. Mike's Office PC" required>
                    </div>
                    <div class="form-group">
                        <label>Notes <span style="color:var(--text-muted)">(optional)</span></label>
                        <input type="text" name="notes" placeholder="Short description">
                    </div>
                </div>

                <div class="form-group" style="margin-bottom:16px">
                    <label>Profile <span style="color:var(--text-muted)">(optional — applies zone and config settings automatically)</span></label>
                    <select name="profile_id" id="add-profile-select" onchange="onProfileChange(this.value)">
                        <option value="">None — configure manually below</option>
                        {% for profile in profiles %}
                        <option value="{{ profile.id }}">{{ profile.name }}{% if profile.zone_name %} — {{ profile.zone_name }}{% endif %}</option>
                        {% endfor %}
                    </select>
                </div>

                <!-- Profile summary shown when a profile is selected -->
                <div id="add-profile-summary" style="display:none; margin-bottom:16px; padding:12px 14px; background:var(--surface-raised); border:1px solid var(--color-info); border-radius:var(--radius-sm); font-size:var(--font-sm); color:var(--text-secondary)">
                    <strong style="color:var(--color-info)">Profile applied:</strong>
                    <span id="add-profile-summary-text"></span>
                    <br><small style="color:var(--text-muted)">Config settings inherited from profile. Edit the profile to change them for all linked peers.</small>
                </div>

                <!-- Manual config fields — hidden when profile is selected -->
                <div id="add-manual-config">
                    <div class="form-group" style="margin-bottom:16px">
                        <label>Zone</label>
                        <select id="add-zone-select" onchange="document.getElementById('add-zone-hidden').value=this.value">
                            <option value="">Select zone…</option>
                            {% for zone in zones %}
                            <option value="{{ zone.id }}">{{ zone.name }} ({{ zone.subnet }})</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="form-group" style="margin-bottom:16px">
                        <label>Allowed IPs <span style="color:var(--text-muted)">(what traffic the client routes through VPN)</span></label>
                        <input type="text" name="custom_allowed_ips" id="add-allowed-ips" placeholder="172.16.0.0/16 (leave blank for full VPN subnet)">
                    </div>

                    <div style="background:var(--surface-input); border:1px solid var(--border-input); border-radius:var(--radius-sm); padding:14px; margin-bottom:16px">
                        <div class="form-check" style="margin-bottom:10px">
                            <input type="checkbox" id="add-is-gateway" name="is_gateway" value="1" onchange="toggleGateway('add')">
                            <label for="add-is-gateway">This peer is a site gateway (routes subnet traffic)</label>
                        </div>
                        <div id="add-gateway-fields" style="display:none">
                            <div class="form-group">
                                <label>Subnets to Advertise <span style="color:var(--text-muted)">(comma-separated CIDR)</span></label>
                                <input type="text" name="gateway_subnet" placeholder="e.g. 192.168.99.0/24, 10.0.0.0/24">
                            </div>
                        </div>
                    </div>

                    <div style="margin-bottom:16px">
                        <button type="button" class="advanced-toggle" onclick="toggleAdvanced('add-advanced')">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:12px;height:12px"><polyline points="6 9 12 15 18 9"/></svg>
                            Advanced options
                        </button>
                        <div id="add-advanced" style="display:none; margin-top:10px; padding:14px; background:var(--surface-input); border:1px solid var(--border-input); border-radius:var(--radius-sm)">
                            <div class="form-group" style="margin-bottom:14px">
                                <label>Hostname <span style="color:var(--text-muted)">(DNS — optional)</span></label>
                                <input type="text" name="hostname" id="add-hostname" placeholder="e.g. proxmox" pattern="[a-z0-9\-]+" title="Lowercase letters, numbers and hyphens only">
                                <small style="color:var(--text-muted)">Resolved as <code>hostname.zone.suffix</code> when DNS is enabled.</small>
                            </div>
                            <div class="form-group" style="margin-bottom:14px">
                                <label>Short Alias <span style="color:var(--text-muted)">(DNS — optional)</span></label>
                                <input type="text" name="dns_alias" id="add-dns-alias" placeholder="e.g. dev-server" pattern="[a-z0-9\-]+" title="Lowercase letters, numbers and hyphens only">
                                <small style="color:var(--text-muted)">Direct short name: <code>alias.suffix</code></small>
                            </div>
                            <div class="form-group">
                                <label style="display:flex; align-items:center; gap:10px; cursor:pointer; font-weight:normal">
                                    <input type="checkbox" name="dns_use_server" id="add-dns-use-server" value="1" checked>
                                    Inject SkonaGuard DNS into this peer's config
                                </label>
                                <small style="color:var(--text-muted)">Allows hostname resolution (e.g. <code>peer.zone.skona</code>). Uncheck for headless peers that don't need DNS.</small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Zone hidden field used when profile supplies zone -->
                <input type="hidden" name="zone_id" id="add-zone-hidden" value="">
                <input type="hidden" name="force_gateway" id="add-force-gateway" value="0">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" onclick="closeModal('modal-add')">Cancel</button>
                <button type="submit" class="btn btn-primary">Create Peer</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Peer Modal -->
<div class="modal-backdrop" id="modal-edit">
    <div class="modal" style="max-width:600px">
        <div class="modal-header">
            <span class="modal-title">Edit Peer</span>
            <button class="modal-close" onclick="closeModal('modal-edit')">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <form method="POST" action="" id="form-edit">
            <div class="modal-body">
                <div class="form-row" style="margin-bottom:16px">
                    <div class="form-group">
                        <label>Peer Name</label>
                        <input type="text" id="edit-name" name="name" required>
                    </div>
                    <div class="form-group">
                        <label>Zone</label>
                        <input type="text" id="edit-zone" readonly style="opacity:0.6; cursor:not-allowed">
                    </div>
                </div>
                <div class="form-group" style="margin-bottom:16px">
                    <label>Profile</label>
                    <select id="edit-profile" name="profile_id">
                        <option value="">None</option>
                        {% for profile in profiles %}
                        <option value="{{ profile.id }}">{{ profile.name }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div style="margin-bottom:16px">
                    <button type="button" class="advanced-toggle" onclick="toggleAdvanced('edit-advanced')">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:12px;height:12px"><polyline points="6 9 12 15 18 9"/></svg>
                        Advanced options
                    </button>
                    <div id="edit-advanced" style="display:none; margin-top:10px; padding:14px; background:var(--surface-input); border:1px solid var(--border-input); border-radius:var(--radius-sm)">
                        <div class="form-group" style="margin-bottom:14px">
                            <label>Hostname <span style="color:var(--text-muted)">(DNS — optional)</span></label>
                            <input type="text" id="edit-hostname" name="hostname" placeholder="e.g. proxmox" pattern="[a-z0-9\-]+" title="Lowercase letters, numbers and hyphens only">
                            <small style="color:var(--text-muted)">Resolved as <code>hostname.zone.suffix</code> when DNS is enabled.</small>
                        </div>
                        <div class="form-group" style="margin-bottom:14px">
                            <label>Short Alias <span style="color:var(--text-muted)">(DNS — optional)</span></label>
                            <input type="text" id="edit-dns-alias" name="dns_alias" placeholder="e.g. dev-server" pattern="[a-z0-9\-]+" title="Lowercase letters, numbers and hyphens only">
                            <small style="color:var(--text-muted)">Direct short name: <code>alias.suffix</code></small>
                        </div>
                        <div class="form-group">
                            <label style="display:flex; align-items:center; gap:10px; cursor:pointer; font-weight:normal">
                                <input type="checkbox" name="dns_use_server" id="edit-dns-use-server" value="1">
                                Inject SkonaGuard DNS into this peer's config
                            </label>
                            <small style="color:var(--text-muted)">Allows hostname resolution (e.g. <code>peer.zone.skona</code>). Uncheck for headless peers that don't need DNS.</small>
                        </div>
                    </div>
                </div>
                <div class="form-group" style="margin-bottom:16px">
                    <label>Allowed IPs</label>
                    <input type="text" id="edit-allowed" name="custom_allowed_ips">
                </div>
                <div class="form-group" style="margin-bottom:16px">
                    <label>Notes</label>
                    <input type="text" id="edit-notes" name="notes">
                </div>
                <div style="background:var(--surface-input); border:1px solid var(--border-input); border-radius:var(--radius-sm); padding:14px; margin-bottom:16px">
                    <div class="form-check" style="margin-bottom:10px">
                        <input type="checkbox" id="edit-is-gateway" name="is_gateway" value="1" onchange="toggleGateway('edit')">
                        <label for="edit-is-gateway">This peer is a site gateway</label>
                    </div>
                    <div id="edit-gateway-fields" style="display:none">
                        <div class="form-group">
                            <label>Subnets to Advertise</label>
                            <input type="text" id="edit-gateway-subnet" name="gateway_subnet">
                        </div>
                    </div>
                </div>
                <div class="form-check">
                    <input type="checkbox" id="edit-enabled" name="enabled" value="1">
                    <label for="edit-enabled">Peer enabled</label>
                </div>
                <input type="hidden" name="force_gateway" id="edit-force-gateway" value="0">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" onclick="closeModal('modal-edit')">Cancel</button>
                <button type="submit" class="btn btn-primary">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<!-- QR Modal -->
<div class="modal-backdrop" id="modal-qr">
    <div class="modal" style="max-width:380px">
        <div class="modal-header">
            <span class="modal-title" id="qr-modal-title">Config QR Code</span>
            <button class="modal-close" onclick="closeModal('modal-qr')">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="modal-body" style="text-align:center">
            <div id="qr-container" style="display:flex; justify-content:center; margin-bottom:12px; min-height:200px; align-items:center;">
                <span style="color:var(--text-muted)">Loading…</span>
            </div>
            <p style="font-size:var(--font-sm); color:var(--text-secondary)">Scan with the WireGuard app to import configuration.</p>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-ghost" onclick="closeModal('modal-qr')">Close</button>
        </div>
    </div>
</div>

<!-- Token Modal -->
<div class="modal-backdrop" id="modal-token">
    <div class="modal" style="max-width:480px">
        <div class="modal-header">
            <span class="modal-title" id="token-modal-title">Create Share Link</span>
            <button class="modal-close" onclick="closeModal('modal-token')">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="modal-body">
            <div class="form-row" style="margin-bottom:16px">
                <div class="form-group">
                    <label>Link Expiry</label>
                    <select id="token-expires">
                        <option value="1h">1 Hour</option>
                        <option value="24h" selected>24 Hours</option>
                        <option value="7d">7 Days</option>
                        <option value="">No Expiry</option>
                    </select>
                </div>
                {% if has_lan_endpoint %}
                <div class="form-group">
                    <label>Config Type</label>
                    <select id="token-mode">
                        <option value="wan">WAN (internet)</option>
                        <option value="lan">LAN (local network)</option>
                    </select>
                </div>
                {% endif %}
            </div>
            <button class="btn btn-primary" id="token-generate-btn" onclick="generateToken()">Generate Link</button>
            <div class="token-result" id="token-result">
                <p style="font-size:var(--font-sm); color:var(--text-secondary); margin-top:16px; margin-bottom:8px">Share this link to allow direct config download:</p>
                <div class="copy-wrap">
                    <div class="code-block" id="token-url" style="word-break:break-all"></div>
                    <button class="copy-btn" onclick="copyTokenUrl()" title="Copy">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                    </button>
                </div>
                <p id="token-expires-note" style="font-size:0.7rem; color:var(--text-muted); margin-top:6px"></p>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-ghost" onclick="closeModal('modal-token')">Close</button>
        </div>
    </div>
</div>

<!-- Gateway Subnet Conflict Warning Modal -->
<div class="modal-backdrop" id="modal-subnet-conflict">
    <div class="modal" style="max-width:520px">
        <div class="modal-header" style="border-bottom-color:var(--color-warning)">
            <span class="modal-title" style="color:var(--color-warning)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:18px;height:18px;vertical-align:-3px;margin-right:6px"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                Subnet Conflict Detected
            </span>
            <button class="modal-close" onclick="cancelConflict()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="modal-body">
            <p style="color:var(--text-secondary); margin-bottom:14px">
                The subnet(s) you're advertising overlap with an existing gateway peer:
            </p>
            <div id="conflict-list" style="margin-bottom:16px; font-size:var(--font-sm)"></div>
            <div style="background:var(--surface-input); border:1px solid var(--color-warning); border-radius:var(--radius-sm); padding:12px 14px; font-size:var(--font-sm); color:var(--text-secondary)">
                <strong style="color:var(--color-warning)">What this means:</strong>
                WireGuard can only route a subnet to <em>one</em> peer at a time — the last entry in the config wins.
                If both peers are on <strong>different physical networks</strong>, only one will be reachable via that subnet.
                This is fine for <strong>redundancy</strong> (same physical network, two gateway machines), but will cause
                silent routing failures or accidental cross-site exposure otherwise.
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-ghost" onclick="cancelConflict()">Cancel</button>
            <button type="button" class="btn" id="conflict-save-anyway" onclick="saveAnywayFromConflict()" style="background:var(--color-warning); color:#000; border-color:var(--color-warning)">Save Anyway</button>
        </div>
    </div>
</div>

<!-- Delete Confirm Modal -->
<div class="modal-backdrop" id="modal-delete">
    <div class="modal" style="max-width:400px">
        <div class="modal-header">
            <span class="modal-title">Delete Peer</span>
            <button class="modal-close" onclick="closeModal('modal-delete')">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="modal-body">
            <p style="color:var(--text-secondary)">Are you sure you want to delete <strong id="delete-peer-name"></strong>? This will remove them from WireGuard immediately.</p>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-ghost" onclick="closeModal('modal-delete')">Cancel</button>
            <form method="POST" action="" id="form-delete" style="margin:0">
                <button type="submit" class="btn btn-danger">Delete</button>
            </form>
        </div>
    </div>
</div>

{% endblock %}

{% block scripts %}
<script src="/assets/qrcode.min.js"></script>
<script>
let currentTokenPeerId = null;

function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

document.querySelectorAll('.modal-backdrop').forEach(b => {
    b.addEventListener('click', e => { if (e.target === b) b.classList.remove('open'); });
});

function toggleAdvanced(id) {
    const el = document.getElementById(id);
    el.style.display = el.style.display === 'none' ? 'block' : 'none';
}

function toggleGateway(prefix) {
    const cb     = document.getElementById(prefix + '-is-gateway');
    const fields = document.getElementById(prefix + '-gateway-fields');
    fields.style.display = cb.checked ? 'block' : 'none';
}

function onProfileChange(profileId) {
    const manualConfig  = document.getElementById('add-manual-config');
    const summary       = document.getElementById('add-profile-summary');
    const summaryText   = document.getElementById('add-profile-summary-text');
    const zoneSelect    = document.getElementById('add-zone-select');
    const zoneHidden    = document.getElementById('add-zone-hidden');

    if (!profileId) {
        manualConfig.style.display = 'block';
        summary.style.display = 'none';
        zoneSelect.disabled = false;
        zoneHidden.value = zoneSelect.value;
        return;
    }

    fetch('/profiles/' + profileId + '/data')
        .then(r => r.json())
        .then(async p => {
            const parts = [];
            if (p.zone_name)          parts.push('Zone: ' + p.zone_name + ' (' + (p.zone_subnet || '') + ')');
            if (p.custom_allowed_ips) parts.push('Allowed IPs: ' + p.custom_allowed_ips);
            else                      parts.push('Allowed IPs: 172.16.0.0/16 (default)');
            if (p.is_gateway)         parts.push('Gateway' + (p.gateway_subnet ? ': ' + p.gateway_subnet : ''));
            if (p.dns && p.dns !== 'skip') parts.push('DNS: ' + p.dns);

            summaryText.textContent = parts.join(' · ');
            summary.style.display = 'block';
            manualConfig.style.display = 'none';

            zoneSelect.required = false;
            zoneSelect.disabled = true;
            zoneHidden.value = p.zone_id || '';

            if (p.is_gateway && p.gateway_subnet) {
                const addForm    = document.querySelector('#modal-add form');
                const forceInput = document.getElementById('add-force-gateway');
                if (forceInput && forceInput.value !== '1') {
                    const fakeInput = { value: p.gateway_subnet };
                    _conflictOnProfileSelect = profileId;
                    await checkGatewayConflicts(addForm, fakeInput, forceInput, null);
                }
            }
        })
        .catch(() => {
            manualConfig.style.display = 'block';
            summary.style.display = 'none';
            zoneSelect.disabled = false;
            zoneHidden.value = zoneSelect.value;
        });
}

function openEditModal(peer) {
    document.getElementById('edit-name').value           = peer.name;
    document.getElementById('edit-zone').value           = peer.zone_name + ' (' + peer.zone_subnet + ')';
    document.getElementById('edit-dns-use-server').checked = (peer.dns ?? '') !== 'skip';
    document.getElementById('edit-hostname').value       = peer.hostname ?? '';
    document.getElementById('edit-dns-alias').value      = peer.dns_alias ?? '';
    document.getElementById('edit-notes').value          = peer.notes ?? '';
    document.getElementById('edit-allowed').value        = peer.custom_allowed_ips ?? '';
    document.getElementById('edit-enabled').checked      = peer.enabled == 1;
    document.getElementById('edit-is-gateway').checked   = peer.is_gateway == 1;
    document.getElementById('edit-gateway-subnet').value = peer.gateway_subnet ?? '';
    document.getElementById('edit-gateway-fields').style.display = peer.is_gateway == 1 ? 'block' : 'none';

    const profileSel = document.getElementById('edit-profile');
    profileSel.value = peer.profile_id ?? '';

    document.getElementById('form-edit').action = '/peers/' + peer.id;
    openModal('modal-edit');
}

function confirmDelete(id, name) {
    document.getElementById('delete-peer-name').textContent = name;
    document.getElementById('form-delete').action = '/peers/' + id + '/delete';
    openModal('modal-delete');
}

function toggleDownloadMenu(peerId) {
    const menu = document.getElementById('dl-menu-' + peerId);
    const isOpen = menu.style.display !== 'none';
    document.querySelectorAll('.btn-split-menu').forEach(m => m.style.display = 'none');
    menu.style.display = isOpen ? 'none' : 'block';
}

document.addEventListener('click', e => {
    if (!e.target.closest('.btn-split')) {
        document.querySelectorAll('.btn-split-menu').forEach(m => m.style.display = 'none');
    }
});

function showQr(peerId, peerName, mode) {
    mode = mode || 'wan';
    const label = mode === 'lan' ? ' (LAN)' : ' (WAN)';
    document.getElementById('qr-modal-title').textContent = 'QR Code — ' + peerName + label;
    document.getElementById('qr-container').innerHTML = '<span style="color:var(--text-muted)">Loading…</span>';
    openModal('modal-qr');

    fetch('/peers/' + peerId + '/qr?mode=' + mode)
        .then(r => r.json())
        .then(data => {
            if (typeof QRCode === 'undefined') {
                throw new Error('QRCode library not loaded');
            }
            const conf = atob(data.config_b64);
            document.getElementById('qr-container').innerHTML = '<div id="qr-canvas"></div>';
            new QRCode(document.getElementById('qr-canvas'), {
                text: conf,
                width: 280,
                height: 280,
                colorDark: '#000000',
                colorLight: '#ffffff',
            });
        })
        .catch(err => {
            document.getElementById('qr-container').innerHTML = '<span style="color:var(--color-danger)">Failed to generate QR code</span>';
        });
}

function openTokenModal(peerId, peerName) {
    currentTokenPeerId = peerId;
    document.getElementById('token-modal-title').textContent = 'Share Link — ' + peerName;
    document.getElementById('token-result').classList.remove('show');
    document.getElementById('token-url').textContent = '';
    document.getElementById('token-expires-note').textContent = '';
    openModal('modal-token');
}

function generateToken() {
    if (!currentTokenPeerId) return;
    const expires = document.getElementById('token-expires').value;
    const mode    = document.getElementById('token-mode') ? document.getElementById('token-mode').value : 'wan';
    const btn = document.getElementById('token-generate-btn');
    btn.disabled = true;
    btn.textContent = 'Generating…';

    fetch('/peers/' + currentTokenPeerId + '/token', {
        method: 'POST',
        headers: {'Content-Type': 'application/x-www-form-urlencoded'},
        body: 'expires=' + encodeURIComponent(expires) + '&mode=' + encodeURIComponent(mode),
    })
    .then(r => r.json())
    .then(data => {
        document.getElementById('token-url').textContent = data.url;
        if (data.expires_at) {
            document.getElementById('token-expires-note').textContent = 'Expires: ' + data.expires_at;
        } else {
            document.getElementById('token-expires-note').textContent = 'No expiry';
        }
        document.getElementById('token-result').classList.add('show');
    })
    .catch(() => alert('Failed to generate link'))
    .finally(() => {
        btn.disabled = false;
        btn.textContent = 'Generate Link';
    });
}

function copyTokenUrl() {
    const text = document.getElementById('token-url').textContent;
    navigator.clipboard.writeText(text).catch(() => {});
}

let _pendingConflictForm      = null;
let _conflictOnProfileSelect  = null;

async function checkGatewayConflicts(form, subnetInput, forceInput, excludeId) {
    const subnet = subnetInput ? subnetInput.value.trim() : '';
    if (!subnet) return true;

    if (forceInput && forceInput.value === '1') return true;

    try {
        const url = '/peers/check-subnet?subnets=' + encodeURIComponent(subnet)
            + (excludeId ? '&exclude_id=' + excludeId : '');
        const resp = await fetch(url);
        const data = await resp.json();

        if (!data.conflicts || data.conflicts.length === 0) return true;

        const list = document.getElementById('conflict-list');
        list.innerHTML = data.conflicts.map(c =>
            `<div style="padding:8px 12px; margin-bottom:6px; background:var(--surface-input); border-left:3px solid var(--color-warning); border-radius:var(--radius-sm)">
                <strong>${c.peer_name}</strong> <span style="color:var(--text-muted)">(${c.peer_vpn_ip})</span>
                already advertises <code>${c.conflicting_subnet}</code>
                which overlaps with <code>${c.new_subnet}</code>
            </div>`
        ).join('');

        _pendingConflictForm = { form, forceInput };
        openModal('modal-subnet-conflict');
        return false;
    } catch {
        return true;
    }
}

function saveAnywayFromConflict() {
    closeModal('modal-subnet-conflict');
    _conflictOnProfileSelect = null;
    if (_pendingConflictForm) {
        _pendingConflictForm.forceInput.value = '1';
        _pendingConflictForm.form.submit();
        _pendingConflictForm = null;
    }
}

function cancelConflict() {
    closeModal('modal-subnet-conflict');
    if (_conflictOnProfileSelect !== null) {
        document.getElementById('add-profile-select').value = '';
        onProfileChange('');
        _conflictOnProfileSelect = null;
    }
    _pendingConflictForm = null;
}

document.addEventListener('DOMContentLoaded', () => {
    const addForm = document.querySelector('#modal-add form');
    if (addForm) {
        addForm.addEventListener('submit', async function(e) {
            const gwCb = document.getElementById('add-is-gateway');
            if (!gwCb || !gwCb.checked) return;
            const forceInput = document.getElementById('add-force-gateway');
            if (forceInput && forceInput.value === '1') return;
            e.preventDefault();
            const subnetInput = addForm.querySelector('[name="gateway_subnet"]');
            const ok = await checkGatewayConflicts(addForm, subnetInput, forceInput, null);
            if (ok) addForm.submit();
        });
    }

    const editForm = document.getElementById('form-edit');
    if (editForm) {
        editForm.addEventListener('submit', async function(e) {
            const gwCb = document.getElementById('edit-is-gateway');
            if (!gwCb || !gwCb.checked) return;
            const forceInput = document.getElementById('edit-force-gateway');
            if (forceInput && forceInput.value === '1') return;
            e.preventDefault();
            const subnetInput = editForm.querySelector('[name="gateway_subnet"]');
            const peerId = editForm.action.match(/\/peers\/(\d+)/)?.[1] ?? null;
            const ok = await checkGatewayConflicts(editForm, subnetInput, forceInput, peerId);
            if (ok) editForm.submit();
        });
    }
});

setTimeout(() => {
    const el = document.getElementById('flash-msg');
    if (el) el.style.opacity = '0';
}, 4000);

function fmtBytes(b) {
    if (b === null || b === undefined) return null;
    if (b < 1024)       return b + ' B';
    if (b < 1048576)    return (b / 1024).toFixed(1) + ' KB';
    if (b < 1073741824) return (b / 1048576).toFixed(1) + ' MB';
    return (b / 1073741824).toFixed(2) + ' GB';
}

function refreshPeerStats() {
    fetch('/dashboard/status')
        .then(r => r.json())
        .then(data => {
            Object.entries(data.peers).forEach(([pubkey, s]) => {
                const row = document.querySelector('tr[data-pubkey="' + pubkey + '"]');
                if (!row) return;
                const td = row.querySelector('.peer-transfer');
                if (!td) return;
                if (s.rx !== null && s.rx !== undefined) {
                    td.innerHTML = '<span style="color:var(--color-success)">↓ ' + fmtBytes(s.rx) + '</span> <span style="color:var(--color-primary)">↑ ' + fmtBytes(s.tx) + '</span>';
                } else {
                    td.textContent = '—';
                }
            });
        })
        .catch(() => {});
}

refreshPeerStats();
setInterval(refreshPeerStats, 10000);
</script>
{% endblock %}
