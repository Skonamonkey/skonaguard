{% extends "partials/layout.twig" %}

{% block title %}Dashboard &mdash; SkonaGuard{% endblock %}
{% block page_title %}Dashboard{% endblock %}

{% block head %}
<style>
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1rem;
        margin-bottom: 1.75rem;
    }

    .stat-card {
        background: var(--surface-card);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-lg);
        padding: 1.25rem 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }
    .stat-label {
        font-size: var(--font-sm);
        color: var(--text-muted);
        font-weight: 500;
    }
    .stat-value {
        font-size: 2rem;
        font-weight: 700;
        color: var(--text-primary);
        line-height: 1;
    }
    .stat-card.primary .stat-value { color: var(--color-primary); }
    .stat-card.success .stat-value { color: var(--color-success); }

    .section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1rem;
    }
    .section-title {
        font-size: var(--font-md);
        font-weight: 600;
        color: var(--text-primary);
    }
    .btn-sm {
        padding: 0.4rem 0.9rem;
        background: var(--color-primary);
        color: #fff;
        border-radius: var(--radius-sm);
        font-size: var(--font-sm);
        font-weight: 600;
        text-decoration: none;
        transition: background var(--transition);
    }
    .btn-sm:hover { background: var(--color-primary-hover); }

    .table-card {
        background: var(--surface-card);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-lg);
        overflow: hidden;
    }
    table { width: 100%; border-collapse: collapse; }
    th {
        padding: 0.75rem 1rem;
        font-size: var(--font-sm);
        font-weight: 600;
        color: var(--text-muted);
        text-align: left;
        background: var(--surface-raised);
        border-bottom: 1px solid var(--border-color);
    }
    td {
        padding: 0.75rem 1rem;
        font-size: var(--font-sm);
        color: var(--text-secondary);
        border-bottom: 1px solid var(--border-subtle);
    }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: var(--surface-hover); }

    .badge {
        display: inline-block;
        padding: 0.2rem 0.6rem;
        border-radius: 99px;
        font-size: 0.7rem;
        font-weight: 600;
    }
    .badge-blue   { background: var(--color-primary-muted); color: var(--color-primary); }
    .badge-green  { background: var(--color-success-muted); color: var(--color-success); }
    .badge-purple { background: var(--color-purple-muted);  color: var(--color-purple); }
    .badge-grey   { background: var(--surface-raised); color: var(--text-muted); }

    .peer-dot { width:8px; height:8px; border-radius:50%; display:inline-block; flex-shrink:0; }
    .peer-dot.online  { background:var(--color-success); box-shadow:0 0 5px var(--color-success); }
    .peer-dot.offline { background:var(--color-danger); }
    .peer-dot.idle    { background:var(--text-muted); }

    .transfer { font-family:monospace; font-size:0.75rem; color:var(--text-muted); white-space:nowrap; }
    .transfer .rx { color:var(--color-success); }
    .transfer .tx { color:var(--color-primary); }

    .empty-state {
        text-align: center;
        padding: 3rem 1rem;
        color: var(--text-muted);
    }
    .empty-state p { font-size: var(--font-sm); margin-top: 0.5rem; }

    .wg-status {
        background: var(--surface-card);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-lg);
        padding: 1rem 1.25rem;
        margin-bottom: 1.75rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: var(--font-sm);
    }
    .status-dot {
        width: 10px; height: 10px;
        border-radius: 50%;
        flex-shrink: 0;
    }
    .status-dot.online  { background: var(--color-success); box-shadow: 0 0 6px var(--color-success); }
    .status-dot.offline { background: var(--color-danger); }
</style>
{% endblock %}

{% block content %}
<div class="wg-status">
    <div class="status-dot online"></div>
    <span style="color:var(--text-primary); font-weight:600;">WireGuard</span>
    <span style="color:var(--text-muted);">running &mdash; interface wg0 active</span>
</div>

<div class="stats-grid">
    <div class="stat-card primary">
        <div class="stat-label">Total Peers</div>
        <div class="stat-value">{{ total_peers }}</div>
    </div>
    <div class="stat-card success">
        <div class="stat-label">Connected</div>
        <div class="stat-value" id="stat-connected">{{ connected_peers }}</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Zones</div>
        <div class="stat-value">{{ total_zones }}</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Profiles</div>
        <div class="stat-value">{{ total_profiles }}</div>
    </div>
</div>

<div class="section-header">
    <div class="section-title">Peer Status</div>
    <a href="/peers" class="btn-sm">+ Add Peer</a>
</div>

<div class="table-card">
    {% if peers|length > 0 %}
    <table>
        <thead>
            <tr>
                <th style="width:16px"></th>
                <th>Name</th>
                <th>Zone</th>
                <th>VPN IP</th>
                <th>Endpoint</th>
                <th>Last Handshake</th>
                <th>Transfer (↓ rx / ↑ tx)</th>
                <th>Type</th>
            </tr>
        </thead>
        <tbody>
            {% for peer in peers %}
            {% if peer.enabled %}
            <tr data-pubkey="{{ peer.public_key }}">
                <td>
                    {% if peer.wg_connected %}
                        <span class="peer-dot online" title="Connected"></span>
                    {% elseif peer.wg_handshake_ts > 0 %}
                        <span class="peer-dot idle" title="Idle / no recent handshake"></span>
                    {% else %}
                        <span class="peer-dot offline" title="Never connected"></span>
                    {% endif %}
                </td>
                <td style="color:var(--text-primary); font-weight:500;">{{ peer.name }}</td>
                <td><span class="badge badge-blue">{{ peer.zone_name }}</span></td>
                <td style="font-family:monospace; font-size:0.75rem;">{{ peer.vpn_ip }}</td>
                <td class="peer-endpoint" style="font-family:monospace; font-size:0.75rem; color:var(--text-muted);">
                    {{ peer.wg_endpoint ?? '—' }}
                </td>
                <td class="peer-handshake" style="font-size:0.75rem; color:var(--text-muted);">
                    {{ peer.wg_handshake_ago ?? 'Never' }}
                </td>
                <td class="peer-transfer transfer">
                    {% if peer.wg_rx is not null %}
                        <span class="rx">↓ {{ (peer.wg_rx / 1024)|round(1) }} KB</span>
                        &nbsp;
                        <span class="tx">↑ {{ (peer.wg_tx / 1024)|round(1) }} KB</span>
                    {% else %}
                        <span style="color:var(--text-muted)">—</span>
                    {% endif %}
                </td>
                <td>
                    {% if peer.is_gateway %}
                        <span class="badge badge-purple">Gateway</span>
                    {% else %}
                        <span class="badge badge-green">Client</span>
                    {% endif %}
                </td>
            </tr>
            {% endif %}
            {% endfor %}
        </tbody>
    </table>
    {% else %}
    <div class="empty-state">
        <p>No peers yet. <a href="/peers" style="color:var(--color-primary);">Add your first peer</a> to get started.</p>
    </div>
    {% endif %}
</div>
{% endblock %}

{% block scripts %}
<script>
function fmtBytes(b) {
    if (b === null || b === undefined) return null;
    if (b < 1024)       return b + ' B';
    if (b < 1048576)    return (b / 1024).toFixed(1) + ' KB';
    if (b < 1073741824) return (b / 1048576).toFixed(1) + ' MB';
    return (b / 1073741824).toFixed(2) + ' GB';
}

function refreshStatus() {
    fetch('/dashboard/status')
        .then(r => r.json())
        .then(data => {
            const statEl = document.getElementById('stat-connected');
            if (statEl) statEl.textContent = data.connected_count;

            Object.entries(data.peers).forEach(([pubkey, s]) => {
                const row = document.querySelector('tr[data-pubkey="' + pubkey + '"]');
                if (!row) return;

                const dot = row.querySelector('.peer-dot');
                if (dot) {
                    dot.className = 'peer-dot ' + (s.connected ? 'online' : (s.handshake_ago ? 'idle' : 'offline'));
                    dot.title     = s.connected ? 'Connected' : (s.handshake_ago ? 'Idle / no recent handshake' : 'Never connected');
                }

                const ep = row.querySelector('.peer-endpoint');
                if (ep) ep.textContent = s.endpoint ?? '—';

                const hs = row.querySelector('.peer-handshake');
                if (hs) hs.textContent = s.handshake_ago ?? 'Never';

                const tx = row.querySelector('.peer-transfer');
                if (tx) {
                    if (s.rx !== null && s.rx !== undefined) {
                        tx.innerHTML = '<span class="rx">↓ ' + fmtBytes(s.rx) + '</span>&nbsp;<span class="tx">↑ ' + fmtBytes(s.tx) + '</span>';
                    } else {
                        tx.innerHTML = '<span style="color:var(--text-muted)">—</span>';
                    }
                }
            });
        })
        .catch(() => {});
}

setInterval(refreshStatus, 10000);
</script>
{% endblock %}
